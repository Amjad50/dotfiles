#!/usr/bin/env bash
# Re-encrypt chezmoi *.age secrets whose recipients differ from the current
# config. Files already encrypted to exactly the right recipients are left
# untouched (age re-randomizes ciphertext every run, so blind re-encryption
# would churn every file). Run after adding/removing a machine's age_recipient.
set -euo pipefail

die() { printf 'reencrypt-secrets: %s\n' "$*" >&2; exit 1; }

command -v chezmoi >/dev/null 2>&1 || die "chezmoi not found in PATH"

SRC="$(chezmoi source-path)"
[[ -d "$SRC" ]] || die "chezmoi source dir not found: $SRC"

# Sorted set of recipient stanza tags in an age file (stable per recipient).
tags() {
  python3 -c "
import base64,sys,re
d=open(sys.argv[1]).read()
b=''.join(l for l in d.splitlines() if not l.startswith('-----'))
hdr=base64.b64decode(b).split(b'\n---',1)[0].decode('utf-8','replace')
print(' '.join(sorted(re.findall(r'-> \S+ (\S+)', hdr))))
" "$1"
}

WORK="$(mktemp -d)"
chmod 700 "$WORK"
trap 'rm -rf "$WORK"' EXIT

( umask 077; printf x > "$WORK/probe"; chezmoi encrypt "$WORK/probe" > "$WORK/probe.age" )
WANT="$(tags "$WORK/probe.age")"

mapfile -d '' SECRETS < <(find "$SRC" -type f -name '*.age' -print0)
[[ "${#SECRETS[@]}" -ge 1 ]] || die "no *.age secrets found under $SRC"

changed=0
for f in "${SECRETS[@]}"; do
  rel="${f#"$SRC"/}"
  if [[ "$(tags "$f")" == "$WANT" ]]; then
    echo "  $rel  (unchanged)"
    continue
  fi

  plain="$WORK/plain.bin"
  out="$f.tmp.$$"
  ( umask 077; chezmoi decrypt "$f" > "$plain" ) \
    || die "decrypt failed for $rel (is this machine a current recipient?)"
  chezmoi encrypt "$plain" > "$out" \
    || { rm -f "$out"; die "encrypt failed for $rel"; }
  mv -f "$out" "$f"
  rm -f "$plain"
  echo "  $rel  re-encrypted"
  changed=$((changed + 1))
done

echo "done. $changed file(s) re-encrypted."
