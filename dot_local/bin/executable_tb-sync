#!/usr/bin/env python3
"""tb-sync — sync Thunderbird config between the live `main` profile and the
chezmoi repo source.

    tb-sync save    live profile  ->  chezmoi repo source   (capture changes)
    tb-sync load    chezmoi repo  ->  live profile           (push config out)

Only the curated, declarative config is handled (no mail cache, no secrets):
  • user.js            re-curated from live prefs.js (accounts/servers/tags)
  • mailViews.dat       saved views        (copied verbatim)
  • virtualFolders.dat  saved searches     (copied verbatim)
  • extensions.md       regenerated from live extensions.json — the list of
                        profile-installed add-ons + their store .xpi URLs

After `tb-sync save`, review with `chezmoi cd && git diff`, then commit.
`tb-sync load` prints the add-on download URLs so you can ctrl-click each one,
download the signed .xpi, and install it via the Add-ons UI.
Thunderbird must be closed (it rewrites prefs.js on exit).
"""
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

PROFILE_DIR = Path.home() / ".thunderbird" / "main"
TB_DIR = Path.home() / ".thunderbird"
DAT_FILES = ("mailViews.dat", "virtualFolders.dat")

# Add-ons installed into the profile live here (vs app-global/app-builtin, which
# are the langpacks + built-in themes that ship with Thunderbird — not ours).
PROFILE_ADDON_LOCATIONS = {"app-profile", "app-system-profile"}
# Pull the .xpi URL back out of the generated extensions.md table on `load`.
MD_URL = re.compile(r"\|\s*(https?://\S+?)\s*\|")

# Durable prefs to keep in user.js; everything else in prefs.js is ignored.
WANT = re.compile(
    r'^user_pref\("('
    r"mail\.accountmanager\.|mail\.account\.account\d+\.|mail\.account\.lastKey|"
    r"mail\.identity\.id\d+\.|mail\.server\.server\d+\.|"
    r"mail\.smtpserver\.|mail\.smtpservers|mail\.root\.\w+-rel|"
    r"mailnews\.tags\.|mailnews\.default_sort_order"
    r")"
)
# Machine-specific keys to drop even if they match WANT.
DROP = re.compile(r'\.(directory|lastFilterTime|nextFilterTime|serverIDResponse|clientid)"')

HEADER = """\
// ===========================================================================
// Thunderbird user.js — curated DECLARATIVE config managed by chezmoi
// ===========================================================================
// Human-readable, diffable, portable. Thunderbird applies these at every
// startup. NO passwords (OAuth login per machine). NO binary state tracked.
//
// Regenerated by `tb-sync save`. Installed into ~/.thunderbird/main/user.js
// by run_onchange_setup-thunderbird.
// ==========================================================================="""


def die(msg: str) -> None:
    sys.exit(f"❌ {msg}")


def check_closed() -> None:
    if subprocess.run(["pgrep", "-x", "thunderbird"], stdout=subprocess.DEVNULL).returncode == 0:
        die("Close Thunderbird first (it rewrites prefs.js on exit).")


def source_dir() -> Path:
    # Prefer env vars set by chezmoi when it runs scripts (calling `chezmoi`
    # again from inside a chezmoi-run script fails with a lock/re-entrancy
    # error). $TB_SYNC_SRC lets the run_onchange script pass the dir directly;
    # $CHEZMOI_SOURCE_DIR is chezmoi's own export. Fall back to the CLI for
    # standalone use (e.g. running `tb-save` from your shell).
    if env := os.environ.get("TB_SYNC_SRC"):
        return Path(env)
    if root := os.environ.get("CHEZMOI_SOURCE_DIR"):
        return Path(root) / "private_dot_thunderbird" / "dot_chezmoi-tb"
    root = subprocess.run(
        ["chezmoi", "source-path"], capture_output=True, text=True, check=True
    ).stdout.strip()
    return Path(root) / "private_dot_thunderbird" / "dot_chezmoi-tb"


def read_config(src: Path, name: str) -> bytes | None:
    # Source contents differ by caller: the run_onchange script points at the
    # chezmoi-decrypted staging dir (plaintext present), standalone runs point at
    # the repo source (only encrypted_<name>.age present). Prefer plaintext; fall
    # back to decrypting the .age blob via chezmoi.
    plain = src / name
    if plain.is_file():
        return plain.read_bytes()
    blob = src / f"encrypted_{name}.age"
    if blob.is_file():
        return subprocess.run(
            ["chezmoi", "decrypt", str(blob)], capture_output=True, check=True
        ).stdout
    return None


def write_config(src: Path, name: str, data: bytes) -> bool:
    # Write back to the repo source as encrypted_<name>.age — never plaintext.
    # Skip when the plaintext is unchanged: age re-randomizes ciphertext every
    # run, so re-encrypting identical content would churn the file for nothing.
    if read_config(src, name) == data:
        return False
    blob = subprocess.run(
        ["chezmoi", "encrypt"], input=data, capture_output=True, check=True
    ).stdout
    (src / f"encrypted_{name}.age").write_bytes(blob)
    return True


def curate(prefs: Path) -> str:
    """Build the curated user.js text from a live prefs.js."""
    if not prefs.is_file():
        die(f"live prefs.js not found at {prefs}")
    lines = [
        ln for ln in prefs.read_text().splitlines()
        if WANT.match(ln) and not DROP.search(ln)
    ]
    tags = [ln for ln in lines if "mailnews.tags" in ln or "default_sort_order" in ln]
    mail = [ln for ln in lines if ln not in tags]

    out = [HEADER, ""]
    out += ["// --- Accounts / identities / servers / SMTP --------------------------------"]
    out += mail
    if tags:
        out += ["", "// --- Tags / labels + default sort ------------------------------------------"]
        out += tags
    return "\n".join(out) + "\n"


def read_addons(profile: Path) -> list[dict]:
    """Return the user-installed add-ons from the live extensions.json.

    Only add-ons installed into the profile (location app-profile/-system-profile)
    are ours — that excludes the bundled langpacks and built-in themes. Each entry
    is {name, id, type, url, enabled}, sorted by name. Returns [] (not an error)
    if extensions.json is missing or unparseable, so `save` can leave the existing
    extensions.md untouched rather than wiping it.
    """
    ext_json = profile / "extensions.json"
    if not ext_json.is_file():
        return []
    try:
        addons = json.loads(ext_json.read_text()).get("addons", [])
    except (json.JSONDecodeError, OSError):
        return []

    out = []
    for a in addons:
        if a.get("location") not in PROFILE_ADDON_LOCATIONS:
            continue
        locale = a.get("defaultLocale") or {}
        out.append({
            "name": locale.get("name") or a.get("id", "?"),
            "id": a.get("id", "?"),
            "type": a.get("type", "extension"),
            "url": a.get("sourceURI") or "",
            "enabled": bool(a.get("active")) and not a.get("userDisabled"),
        })
    return sorted(out, key=lambda x: x["name"].lower())


EXT_HEADER = """\
# Thunderbird extensions — install manually per machine

Copying `.xpi` files doesn't work: Thunderbird re-packs installed add-ons
unsigned, so a copied `.xpi` lands `appDisabled` (unsigned) and won't load on a
release build. So on each machine, download the signed `.xpi` from the store URL
below (or search the store UI) and install via Settings → Add-ons and Themes.

`tb-sync load` prints these same URLs so you can ctrl-click each one.

After installing **tbkeys-lite**: Add-ons → tbkeys-lite → Options → paste the
contents of `~/.thunderbird/tbkeys-keymap.json` into the keybindings box → Save.
"""


def render_extensions_md(addons: list[dict]) -> str:
    """Build extensions.md from the live add-on list (auto-generated table)."""
    lines = [
        EXT_HEADER,
        "<!-- Auto-generated by `tb-sync save` from the live profile. Do not hand-edit. -->",
        "",
        "| Add-on | Type | ID | Install URL |",
        "|---|---|---|---|",
    ]
    for a in addons:
        kind = a["type"] + ("" if a["enabled"] else ", disabled")
        url = a["url"] or "_(no download URL — install from the store UI)_"
        lines.append(f"| {a['name']} | {kind} | `{a['id']}` | {url} |")
    return "\n".join(lines) + "\n"


def print_addon_urls(extensions_md: Path) -> None:
    """Print the add-on names + .xpi URLs parsed from extensions.md, one per line,
    so the user can ctrl-click each to download. No-op if the file/table is empty."""
    if not extensions_md.is_file():
        return
    entries = []
    for ln in extensions_md.read_text().splitlines():
        if not ln.startswith("|") or "Install URL" in ln or "---" in ln:
            continue
        cols = [c.strip() for c in ln.strip().strip("|").split("|")]
        if len(cols) < 4:
            continue
        name, kind, _id, url = cols[0], cols[1], cols[2], cols[3]
        m = MD_URL.search("|" + url + "|")
        if m:
            entries.append((name, kind, m.group(1)))
    if not entries:
        return
    print("\n📦 Add-ons to install (ctrl-click to download the .xpi, then add via the Add-ons UI):")
    for name, kind, url in entries:
        print(f"    • {name} ({kind})")
        print(f"      {url}")


def cmd_save() -> None:
    check_closed()
    src = source_dir()
    if not src.is_dir():
        die(f"chezmoi source dir not found: {src}")
    print("→ tb-sync save: live profile → chezmoi repo")

    text = curate(PROFILE_DIR / "prefs.js")
    state = "encrypted" if write_config(src, "user.js", text.encode()) else "unchanged"
    print(f"    • re-curated user.js ({text.count('user_pref(')} prefs, {state})")

    for name in DAT_FILES:
        live = PROFILE_DIR / name
        if live.is_file():
            state = "encrypted" if write_config(src, name, live.read_bytes()) else "unchanged"
            n = sum(
                1 for ln in live.read_text().splitlines()
                if ln.startswith(("name=", "uri="))
            )
            print(f"    • copied {name} ({n} entries, {state})")

    addons = read_addons(PROFILE_DIR)
    if addons:
        (src / "extensions.md").write_text(render_extensions_md(addons))
        n_off = sum(1 for a in addons if not a["enabled"])
        suffix = f", {n_off} disabled" if n_off else ""
        print(f"    • regenerated extensions.md ({len(addons)} add-ons{suffix})")
    else:
        print("    • extensions.json not found — left extensions.md unchanged")

    print("✅ Saved into chezmoi source. Review & commit:")
    print("     chezmoi cd && git diff && git add -A && git commit")


def cmd_load() -> None:
    check_closed()
    src = source_dir()
    if not src.is_dir():
        die(f"chezmoi source dir not found: {src} (run 'chezmoi apply' once)")
    print("→ tb-sync load: chezmoi repo → live profile")
    PROFILE_DIR.mkdir(parents=True, exist_ok=True)

    # Copy curated config straight from repo source into the profile.
    # No chezmoi state touched — never affects other run_onchange scripts.
    user_js = read_config(src, "user.js")
    if user_js is None:
        die(f"user.js not found in {src} (run 'chezmoi apply' once)")
    (PROFILE_DIR / "user.js").write_bytes(user_js)
    print("    • user.js")
    for name in DAT_FILES:
        data = read_config(src, name)
        if data is not None:
            (PROFILE_DIR / name).write_bytes(data)
            print(f"    • {name}")
    keymap = src / "tbkeys-keymap.json"
    if keymap.is_file():
        shutil.copyfile(keymap, TB_DIR / "tbkeys-keymap.json")
    print("✅ Loaded into the live profile. (Accounts apply on next Thunderbird start.)")
    print_addon_urls(src / "extensions.md")


def main() -> None:
    cmd = sys.argv[1] if len(sys.argv) > 1 else ""
    if cmd == "save":
        cmd_save()
    elif cmd == "load":
        cmd_load()
    else:
        sys.exit("usage: tb-sync {save|load}")


if __name__ == "__main__":
    main()
