docs

{{- /* KDE/Plasma configs only make sense on `personal` (KDE laptop) machines. */}}
{{- $tags := concat (list "default") (dig "tags" list (dig "machines" .chezmoi.hostname dict .)) | uniq }}
{{- if not (has "personal" $tags) }}
.config/kglobalshortcutsrc
.config/kxkbrc
.config/dolphinrc
.config/konsolerc
{{- end }}

{{- /* age (the binary, for SSH-key identities) must exist too, else chezmoi's
       built-in age can't decrypt and aborts apply before packages install. */}}
{{- if not (and (stat (printf "%s/.ssh/id_ed25519" .chezmoi.homeDir)) (lookPath "age")) }}
.thunderbird/.chezmoi-tb/user.js
.thunderbird/.chezmoi-tb/virtualFolders.dat
.thunderbird/.chezmoi-tb/mailViews.dat
{{- end }}
